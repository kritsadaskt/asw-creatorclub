# --- AWS S3 (production — Vercel OIDC) ---
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=
AWS_S3_PUBLIC_URL=
AWS_ROLE_ARN=

# --- AWS S3 (local dev with LocalStack) ---
# AWS_ENDPOINT_URL=http://localhost:4566
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
# AWS_S3_PUBLIC_URL=http://localhost:4566/<bucket-name>

# Public (browser) — matches next.config.mjs basePath
NEXT_PUBLIC_BASE_PATH=/creatorclub

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Server-only — service role key bypasses RLS, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_FACEBOOK_APP_ID=

# Cloudflare Turnstile — disabled in app (registration no longer requires it)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# CIS — Friend Get Friends admin “ส่งข้อมูลเข้า CIS” (POST /api/admin/fgf-leads/[id]/cis)
CIS_API_UAT=
CIS_API_PROD=
# Optional Bearer token for CIS
CIS_TOKEN=

# SMTP — used by Next.js Route Handlers (/api/send-password-otp, admin creator emails)
# Either naming style works (aliases on the same line are alternatives, not “set both”).
SMTP_HOST=
SMTP_PORT=587
#
# Credentials (pick one pair):
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
#
# Supabase Edge Functions / some deployments use these names instead:
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=
